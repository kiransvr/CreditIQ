    "cors": "^2.8.5",
    "express": "^4.21.2",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.13.1",
    "typescript": "^5.8.3",
    "xlsx": "^0.18.5",
    "read-excel-file": "^5.8.8",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^6.0.3",
